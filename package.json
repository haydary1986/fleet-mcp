{
  "name": "fleet-mcp",
  "version": "1.0.0",
  "description": "Unified DevOps MCP server: Plesk/SSH fleet, WordPress (wp-cli), Cloudflare, MySQL, GitHub, Docker, Coolify",
  "type": "module",
  "bin": {
    "fleet-mcp": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "start:http": "node dist/http.js",
    "dev:http": "tsx src/http.ts",
    "test": "node --test test/*.test.mjs",
    "test:ci": "npm run build && node --test test/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
