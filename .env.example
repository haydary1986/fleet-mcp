# ─── Fleet SSH (Plesk server) ──────────────────────────────────────────────
# SSH target for run_ssh / wp / mysql / disk_usage. Use a ~/.ssh/config alias
# with key auth (recommended) instead of a password.
FLEET_SSH_TARGET=root@your-server.example.com
# Optional extra ssh flags (port, host-key policy, identity file, etc.)
FLEET_SSH_OPTIONS=-o StrictHostKeyChecking=accept-new
# Reuse one SSH connection across tool calls (faster + avoids fail2ban bans).
FLEET_SSH_MULTIPLEX=true
FLEET_SSH_CONTROL_PERSIST=120s

# ─── WordPress (wp-cli over SSH) ───────────────────────────────────────────
# {domain} is replaced with the site you pass. Override per-call with an
# absolute path if a site's docroot differs (e.g. Plesk siteN docroots).
WP_DOCROOT_TEMPLATE=/var/www/vhosts/{domain}/httpdocs
# Optional: force a PHP binary for wp-cli (e.g. /opt/plesk/php/8.1/bin/php)
WP_CLI_PHP=

# ─── MySQL (over SSH) ──────────────────────────────────────────────────────
# Leave blank to use the server's default auth (e.g. Plesk root socket).
MYSQL_USER=
MYSQL_PASSWORD=

# ─── Cloudflare (two accounts) ─────────────────────────────────────────────
# Comma-separated "key:apiToken" pairs. First one is the default.
CF_ACCOUNTS=main:cf_api_token_here,secondary:cf_api_token_here

# ─── GitHub ────────────────────────────────────────────────────────────────
# Optional — if the `gh` CLI is already authenticated you can leave this blank.
GITHUB_TOKEN=

# ─── Docker ────────────────────────────────────────────────────────────────
# If set (e.g. root@dockerhost), docker runs over SSH to that host.
# Leave blank to run docker on the local machine.
DOCKER_SSH_TARGET=

# ─── Coolify ───────────────────────────────────────────────────────────────
COOLIFY_BASE_URL=https://coolify.example.com
COOLIFY_TOKEN=

# ─── OJS (journal installs over SSH) ───────────────────────────────────────
OJS_PHP_BIN=/opt/plesk/php/8.1/bin/php
OJS_PHP_HANDLER=plesk-php81-fastcgi
OJS_VERSION=3.4.0-9
OJS_DOWNLOAD_BASE=https://pkp.sfu.ca/ojs/download
# Default admin email used by ojs_install when not passed per-call
OJS_ADMIN_EMAIL=admin@example.com
OJS_VHOSTS_ROOT=/var/www/vhosts

# ─── Remote / team mode (HTTP transport) ───────────────────────────────────
# Only needed when running `npm run start:http` (or the Docker image).
MCP_HTTP_PORT=8787
# REQUIRED in HTTP mode — a long random shared secret your team puts in their
# Authorization: Bearer <token> header. Generate: openssl rand -hex 32
MCP_AUTH_TOKEN=

# ─── Misc ──────────────────────────────────────────────────────────────────
FLEET_EXEC_TIMEOUT_MS=60000
